  "info": {
    "description": "Private receiver for Hermes Health Bridge Apple Health exports.",
    "title": "Hermes Health Receiver API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/apple-health/import": {
      "post": {
        "description": "Imports a weekly Apple Health JSON export into SQLite storage.",
        "operationId": "importAppleHealthExport",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AppleHealthImportPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            },
            "description": "Duplicate or replacement import accepted."
          },
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            },
            "description": "New import accepted."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Invalid payload or content type."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Missing or invalid bearer token."
          },
          "413": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Request body too large."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Server-side import failure."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Import Apple Health export",
        "tags": ["Apple Health"]
      }
    },
    "/apple-health/daily-metrics": {
      "get": {
        "description": "Returns normalized daily cumulative metrics.",
        "operationId": "listDailyMetrics",
        "parameters": [
          {
            "in": "query",
            "name": "sourceKey",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "metric",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "startDate",
            "schema": {
              "format": "date",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "endDate",
            "schema": {
              "format": "date",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "default": 500,
              "maximum": 5000,
              "minimum": 1,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DailyMetricsResponse"
                }
              }
            },
            "description": "Daily metrics."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Invalid query parameter."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Missing or invalid bearer token."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "List daily metrics",
        "tags": ["Apple Health"]
      }
    },
    "/apple-health/imports": {
      "get": {
        "description": "Returns import metadata. Raw payloads are not included.",
        "operationId": "listImports",
        "parameters": [
          {
            "in": "query",
            "name": "sourceKey",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Filter imports whose range overlaps this start.",
            "in": "query",
            "name": "start",
            "schema": {
              "format": "date-time",
              "type": "string"
            }
          },
          {
            "description": "Filter imports whose range overlaps this end.",
            "in": "query",
            "name": "end",
            "schema": {
              "format": "date-time",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "default": 500,
              "maximum": 5000,
              "minimum": 1,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportsResponse"
                }
              }
            },
            "description": "Import metadata."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Invalid query parameter."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Missing or invalid bearer token."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "List imports",
        "tags": ["Apple Health"]
      }
    },
    "/apple-health/imports/{id}/payload": {
      "get": {
        "description": "Returns one stored raw Apple Health payload with its import metadata.",
        "operationId": "getImportPayload",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "minimum": 1,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportPayloadResponse"
                }
              }
            },
            "description": "Import payload."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Missing or invalid bearer token."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Import not found."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Get import payload",
        "tags": ["Apple Health"]
      }
    },
    "/apple-health/samples": {
      "get": {
        "description": "Returns normalized sampled metrics such as resting heart rate, HRV, VO2 max, and body mass.",
